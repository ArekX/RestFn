{
  "name": "arekx/restfn",
  "description": "Functional Rest framework",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Aleksandar Panic",
      "email": "arekusanda1@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "ArekX\\RestFn\\": "src/"
    }
  },
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.4",
    "ext-json": "*",
    "ext-mbstring": "*",
    "psr/container": "^2.0",
    "firebase/php-jwt": "^7.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "phpunit/php-code-coverage": "^13.0",
    "carthage-software/mago": "^1.30"
  },
  "scripts": {
    "test": "php vendor/bin/phpunit",
    "test-coverage": "XDEBUG_MODE=coverage php vendor/bin/phpunit --coverage-html coverage --coverage-text",
    "coverage": "XDEBUG_MODE=coverage php vendor/bin/phpunit --coverage-html coverage",
    "coverage-clover": "XDEBUG_MODE=coverage php vendor/bin/phpunit --coverage-clover coverage.xml",
    "format": "mago format",
    "format-check": "mago format --check",
    "lint": "mago lint",
    "analyze": "mago analyze",
    "check": [
      "@format-check",
      "@lint",
      "@analyze",
      "@test"
    ]
  }
}
